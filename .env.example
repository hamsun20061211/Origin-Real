# Copy to `.env.local` and fill in values.
#
# 3D 메쉬 생성: TripoSR 로컬 엔진(기본 포트 8001)이 켜져 있어야 합니다.
#   한 터미널: npm run dev:full  (next dev + npm run engine 동시)
#   또는: 터미널 A → npm run engine  /  터미널 B → npm run dev
# https://console.cloud.google.com/apis/credentials — OAuth 2.0 Client (Web)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Dev: http://localhost:3000  |  Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# TripoSR 엔진 (기본 http://127.0.0.1:8001 — start-engine.ps1 / npm run engine 과 동일). 8000 쓰려면 여기서 맞춤.
# TRIPOSR_URL=http://127.0.0.1:8001
# Next → TripoSR 이미지 생성 전체 대기(ms). HQ·Real-ESRGAN 시 느리면 900000(15분) 등으로 증가 (기본 600000)
# TRIPOSR_GENERATE_TIMEOUT_MS=600000
# 분석/생성 업스트림 재시도(Windows·엔진 잠깐 바쁠 때). 기본: analyze 5회·800ms, generate 4회·900ms
# TRIPOSR_ANALYZE_RETRIES=5
# TRIPOSR_ANALYZE_RETRY_DELAY_MS=800
# TRIPOSR_GENERATE_RETRIES=4
# TRIPOSR_GENERATE_RETRY_DELAY_MS=900
# 헤더 배지(클라이언트)도 같은 주소로: 포트 바꿨으면 함께 설정
# NEXT_PUBLIC_TRIPOSR_URL=http://127.0.0.1:8001

# Dashboard Vehicle/Building 탭: 브라우저가 직접 호출하는 POST /generate-3d 전체 URL (기본 http://localhost:8000/generate-3d)
# NEXT_PUBLIC_DIRECT_GENERATE_3D_URL=http://127.0.0.1:8001/generate-3d

# --- triposr-server (FastAPI) 옵션: LoRA / FP16 / CORS / 터널 ---
# 베이스 TripoSR만 쓰려면: TRIPOSR_SKIP_LORA=1
# LoRA (미설정 시 자동: models/checkpoints/triposr_lora.safetensors + triposr_lora_adapter_config.json)
# TRIPOSR_LORA_SAFETENSORS=C:\...\models\checkpoints\triposr_lora.safetensors
# TRIPOSR_LORA_CONFIG=C:\...\models\checkpoints\triposr_lora_adapter_config.json
# CUDA: RTX 5060 등 — GPU 선택 (기본 cuda:0)
# TRIPOSR_DEVICE=cuda:0
#
# 3D 직전 Real-ESRGAN 2배 업스케일: CUDA 있으면 기본 켜짐. 끄기: TRIPOSR_REALESRGAN=0
# 가중치 자동 다운로드: triposr-server/weights/RealESRGAN_x2plus.pth (또는 TRIPOSR_REALESRGAN_WEIGHTS=경로)
# VRAM 부족 시 타일: TRIPOSR_REALESRGAN_TILE=256
# TRIPOSR_REALESRGAN=1
# TRIPOSR_REALESRGAN_FP16=1
# TRIPOSR_REALESRGAN_OUTSCALE=2
# TRIPOSR_REALESRGAN_PRELOAD=0
# TRIPOSR_REALESRGAN_EMPTY_CACHE=1
#
# CUDA: TRIPOSR_INFER_FP16 이 float32 가 아니면 가중치 float16(.half) 강제 + 추론 직후 empty_cache (mc 해상도·품질 유지)
# 순수 float32 가중치(VRAM↑): 아래 한 줄을 이 파일(.env.local)에 넣으면 됨 — npm run engine / main.py 가 자동 로드
# TRIPOSR_INFER_FP16=float32
# (PowerShell 에서만 켤 때는: $env:TRIPOSR_INFER_FP16 = "float32"  … bash 스타일 KEY=val 는 PS 에서 오류 남)
# TRIPOSR_INFER_FP16=autocast
# torch.compile(첫 실행 컴파일 비용·VRAM 주의): 1
# TRIPOSR_TORCH_COMPILE=0
#
# rembg: 건물·차량 가장자리 정리 (alpha matting, 기본 켜짐). 끄기: TRIPOSR_REMBG_ALPHA_MATTING=0
# TRIPOSR_REMBG_ALPHA_MATTING_FG_THRESHOLD=240
# TRIPOSR_REMBG_ALPHA_MATTING_BG_THRESHOLD=10
# TRIPOSR_REMBG_ALPHA_MATTING_ERODE=10
# 전처리: resize_foreground 이후 정사각형 주변 투명 여백 (변 길이 대비 비율, 기본 0.08)
# TRIPOSR_PREPROCESS_MARGIN_RATIO=0.08
# CORS: 콤마 구분. NEXTAUTH_URL 도 자동 추가됨. 개발만 전체 허용: CORS_ALLOW_ALL=1
# CORS_ORIGINS=https://your-origin-real.example,http://localhost:3000
# JSON 응답 download_url 절대 경로(Cloudflare Tunnel 등)
# PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com

# Text→3D 는 Next 가 아니라 Python 엔진(triposr-server)이 Replicate 를 호출합니다.
# 엔진을 켜는 PowerShell 에서 설정 (또는 Windows 시스템 환경 변수):
#   $env:REPLICATE_API_TOKEN = "r8_..."
# https://replicate.com/account/api-tokens
# 선택: REPLICATE_TEXT_TO_3D_MODEL=cjwbw/shap-e
# 선택: REPLICATE_TEXT_TO_3D_INPUT_EXTRA={"guidance_scale":17}

# --- Photogrammetry (COLMAP) — 별도 터미널: npm run photogrammetry (기본 포트 8002, TripoSR 8001 과 분리)
# COLMAP 이 PATH 에 없으면 Windows 에서 COLMAP.bat 전체 경로:
# COLMAP_EXECUTABLE=C:\Program Files\COLMAP\COLMAP.bat
# PHOTOGRAMMETRY_PORT=8002
# PHOTOGRAMMETRY_DATA_DIR=photogrammetry-server/data
# 작업 전체 타임아웃(초, 0=무제한): PHOTOGRAMMETRY_JOB_TIMEOUT_SEC=7200
# COLMAP 서브프로세스 타임아웃: OR_PHOTO_TIMEOUT_SEC=0
# 희소만 검증(점군 PLY, 표면 메쉬 아님): OR_PHOTO_SPARSE_ONLY=1
# Next 에서 직접 호출 시: PHOTOGRAMMETRY_URL=http://127.0.0.1:8002
